<refentry xml:id="function.pcntl-wifcontinued" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>pcntl_wifcontinued</refname>
  <refpurpose>Verifica se o processo de acompanhamento da criança prosseguiu a partir de uma interrupção no controle do trabalho</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>bool</type><methodname>pcntl_wifcontinued</methodname>
   <methodparam><type>int</type><parameter>status</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Verifica se o processo filho que causou o retorno de
   <function>pcntl_waitpid</function> continuou após uma parada de controle de tarefas.
   Esta função só é útil se a chamada para
   <function>pcntl_waitpid</function> foi feita usando a opção
   <constant>WCONTINUED</constant>.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>status</parameter></term>
    <listitem>
     &pcntl.parameter.status;
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Retorna &true; se o processo filho que causou o retorno de
   <function>pcntl_waitpid</function> continuou a partir de uma parada de controle de trabalho,
   &false; caso contrário.
  </simpara>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>pcntl_waitpid</function></member>
   <member><function>pcntl_wifstopped</function></member>
   <member><function>pcntl_wifexited</function></member>
   <member><function>pcntl_wifsignaled</function></member>
  </simplelist>
 </refsect1>

</refentry>
