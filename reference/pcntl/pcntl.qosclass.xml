<reference xmlns="http://docbook.org/ns/docbook" xml:id="enum.pcntl-qosclass" role="enum">
 <title>A Enumeração Pcntl\QosClass</title>
 <titleabbrev>Pcntl\QosClass</titleabbrev>

 <partintro>
  <section xml:id="enum.pcntl-qosclass.intro">
   &reftitle.intro;
   <simpara>
    A enumeração <enumname>Pcntl\QosClass</enumname> é usada para especificar a prioridade de processo
    de usuário com <function>pcntl_setqos_class</function>.
   </simpara>
  </section>

  <section xml:id="enum.pcntl-qosclass.synopsis">
   &reftitle.enumsynopsis;
   <packagesynopsis>
    <package>Pcntl</package>

    <enumsynopsis>
     <enumname>QosClass</enumname>

     <enumitem>
      <enumidentifier>UserInteractive</enumidentifier>
      <enumitemdescription>
       Executa o processo como o nível de prioridade mais alto.
      </enumitemdescription>
     </enumitem>

     <enumitem>
      <enumidentifier>UserInitiated</enumidentifier>
      <enumitemdescription>
       Executa o processo em nível de alta prioridade, mas abaixo dos UserInteractive.
      </enumitemdescription>
     </enumitem>

     <enumitem>
      <enumidentifier>Default</enumidentifier>
      <enumitemdescription>
       Executa o processo depois de todos os processos de alta prioridade, mas antes dos de baixa prioridade.
      </enumitemdescription>
     </enumitem>

     <enumitem>
      <enumidentifier>Utility</enumidentifier>
      <enumitemdescription>(descrição de Pcntl\QosClass::Utility pendente)</enumitemdescription>
     </enumitem>

     <enumitem>
      <enumidentifier>Background</enumidentifier>
      <enumitemdescription>
       Executa o processo depois que todos os processos de alta prioridade tenham terminado.
      </enumitemdescription>
     </enumitem>
    </enumsynopsis>
   </packagesynopsis>
  </section>
 </partintro>
</reference>
