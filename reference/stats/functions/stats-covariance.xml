<refentry xml:id="function.stats-covariance" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>stats_covariance</refname>
  <refpurpose>Calcula a covariância de dois conjuntos de dados</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>float</type><methodname>stats_covariance</methodname>
   <methodparam><type>array</type><parameter>a</parameter></methodparam>
   <methodparam><type>array</type><parameter>b</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Retorna a covariância de <parameter>a</parameter> e <parameter>b</parameter>.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <para>
   <variablelist>
    <varlistentry>
     <term><parameter>a</parameter></term>
     <listitem>
      <simpara>
       O primeiro array
      </simpara>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>b</parameter></term>
     <listitem>
      <simpara>
       O segundo array
      </simpara>
     </listitem>
    </varlistentry>
   </variablelist>
  </para>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Retorna a covariância de <parameter>a</parameter> e <parameter>b</parameter>,
   ou &false; em caso de falha.
  </simpara>
 </refsect1>

 </refentry>

