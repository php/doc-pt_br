<refentry xml:id="function.stats-rand-gen-f" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>stats_rand_gen_f</refname>
  <refpurpose>Gera um desvio aleatório da distribuição F</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>float</type><methodname>stats_rand_gen_f</methodname>
   <methodparam><type>float</type><parameter>dfn</parameter></methodparam>
   <methodparam><type>float</type><parameter>dfd</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Gera um desvio aleatório da distribuição F (razão de variância) com
   graus de liberdade "dfn" no numerador e graus de liberdade "dfd"
   no denominador. Método: gera diretamente a razão das variáveis ​​qui-quadrado.
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <para>
   <variablelist>
    <varlistentry>
     <term><parameter>dfn</parameter></term>
     <listitem>
      <para>
       Os graus de liberdade no numerador
      </para>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>dfd</parameter></term>
     <listitem>
      <para>
       Os graus de liberdade no denominador
      </para>
     </listitem>
    </varlistentry>
   </variablelist>
  </para>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <para>
   Um desvio aleatório
  </para>
 </refsect1>

 </refentry>

