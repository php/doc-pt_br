<refentry xml:id="function.stats-rand-gen-noncentral-chisquare" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>stats_rand_gen_noncentral_chisquare</refname>
  <refpurpose>Gera um desvio aleatório da distribuição qui-quadrado não centralizada</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>float</type><methodname>stats_rand_gen_noncentral_chisquare</methodname>
   <methodparam><type>float</type><parameter>df</parameter></methodparam>
   <methodparam><type>float</type><parameter>xnonc</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Retorna um desvio aleatório da distribuição qui-quadrado não centralizada com graus de liberdade
   <parameter>df</parameter>, e parâmetro não central <parameter>xnonc</parameter>.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <para>
   <variablelist>
    <varlistentry>
     <term><parameter>df</parameter></term>
     <listitem>
      <simpara>
       Os graus de liberdade
      </simpara>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>xnonc</parameter></term>
     <listitem>
      <simpara>
       O parâmetro de não centralidade
      </simpara>
     </listitem>
    </varlistentry>
   </variablelist>
  </para>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Um desvio aleatório
  </simpara>
 </refsect1>

</refentry>

