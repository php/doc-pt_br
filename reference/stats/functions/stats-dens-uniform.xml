<refentry xml:id="function.stats-dens-uniform" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>stats_dens_uniform</refname>
  <refpurpose>Função de densidade de probabilidade da distribuição uniforme</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>float</type><methodname>stats_dens_uniform</methodname>
   <methodparam><type>float</type><parameter>x</parameter></methodparam>
   <methodparam><type>float</type><parameter>a</parameter></methodparam>
   <methodparam><type>float</type><parameter>b</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Retorna a densidade de probabilidade em <parameter>x</parameter>, onde a
   variável aleatória segue a distribuição uniforme cujo limite inferior é
   <parameter>a</parameter> e o limite superior é <parameter>b</parameter>.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <para>
   <variablelist>
    <varlistentry>
     <term><parameter>x</parameter></term>
     <listitem>
      <simpara>
       O valor no qual a densidade de probabilidade é calculada
      </simpara>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>a</parameter></term>
     <listitem>
      <simpara>
       O limite inferior da distribuição
      </simpara>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>b</parameter></term>
     <listitem>
      <simpara>
       O limite superior da distribuição
      </simpara>
     </listitem>
    </varlistentry>
   </variablelist>
  </para>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   A densidade de probabilidade em <parameter>x</parameter> ou &false; para falha.
  </simpara>
 </refsect1>

</refentry>

