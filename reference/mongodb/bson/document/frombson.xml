<refentry xml:id="mongodb-bson-document.frombson" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>MongoDB\BSON\Document::fromBSON</refname>
  <refpurpose>Constrói uma nova instância de documento a partir de uma string BSON</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>final</modifier> <modifier>static</modifier> <modifier>public</modifier> <type>MongoDB\BSON\Document</type><methodname>MongoDB\BSON\Document::fromBSON</methodname>
   <methodparam><type>string</type><parameter>bson</parameter></methodparam>
  </methodsynopsis>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>bson</parameter> (<type>string</type>)</term>
    <listitem>
     <simpara>
      Uma string contendo um documento no formato BSON.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Retorna uma nova instância de <classname>MongoDB\BSON\Document</classname>.
  </simpara>
 </refsect1>

 <refsect1 role="errors">
  &reftitle.errors;
  <simplelist>
   &mongodb.throws.argumentparsing;
   <member>Lança <classname>MongoDB\Driver\Exception\UnexpectedValueException</classname> se <parameter>bson</parameter> for uma string BSON inválida ou se contiver mais de um documento.</member>
  </simplelist>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>MongoDB\BSON\Document::fromPHP</methodname></member>
   <member><methodname>MongoDB\BSON\Document::fromJSON</methodname></member>
   <member><link xlink:href="&url.mongodb.docs.bson;">Tipos BSON</link></member>
  </simplelist>
 </refsect1>

</refentry>

