<refentry xml:id="mongodb-bson-iterator.current" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>MongoDB\BSON\Iterator::current</refname>
  <refpurpose>Retorna o elemento atual</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>public</modifier> <type>mixed</type><methodname>MongoDB\BSON\Iterator::current</methodname>
   <void/>
  </methodsynopsis>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Retorna o valor do documento atual.
  </simpara>
  <note>
   <simpara>
    Ao encontrar um valor codificado um inteiro de 64 bits na estrutura BSON,
    o valor de retorno deste métodos será uma instância
    <classname>MongoDB\BSON\Int64</classname>.
   </simpara>
  </note>
 </refsect1>

 <refsect1 role="errors">
  &reftitle.errors;
  <simplelist>
   &mongodb.throws.argumentparsing;
   <member>Lança uma <classname>MongoDB\Driver\Exception\LogicException</classname> se o iterador não for válido.</member>
  </simplelist>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><methodname>Iterator::current</methodname></member>
  </simplelist>
 </refsect1>
</refentry>
