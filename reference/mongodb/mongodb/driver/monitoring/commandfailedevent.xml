  <section xml:id="mongodb-driver-monitoring-commandfailedevent.intro">
   &reftitle.intro;
   <simpara>
    A classe <classname>MongoDB\Driver\Monitoring\CommandFailedEvent</classname>
    encapsula informação sobre um comando falhado.
   </simpara>
  </section>
