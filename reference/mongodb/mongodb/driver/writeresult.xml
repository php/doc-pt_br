 <partintro>

<!-- {{{ MongoDB\Driver\WriteResult intro -->
  <section xml:id="mongodb-driver-writeresult.intro">
   &reftitle.intro;
   <simpara>
    A classe <classname>MongoDB\Driver\WriteResult</classname> encapsula
    informações sobre um
    <classname>MongoDB\Driver\BulkWrite</classname> executado e pode ser retornada por
    <methodname>MongoDB\Driver\Manager::executeBulkWrite</methodname>.

   </simpara>
  </section>
<!-- }}} -->

