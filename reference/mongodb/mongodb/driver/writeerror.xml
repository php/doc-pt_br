<!-- {{{ MongoDB\Driver\WriteError properties -->
  <section xml:id="mongodb-driver-writeerror.props">
   &reftitle.properties;
   <variablelist>
    <varlistentry xml:id="mongodb-driver-writeerror.props.message">
     <term><varname>message</varname></term>
     <listitem>
      <simpara>A mensagem de erro.</simpara>
     </listitem>
    </varlistentry>
    <varlistentry xml:id="mongodb-driver-writeerror.props.code">
     <term><varname>code</varname></term>
     <listitem>
      <simpara>O código de erro.</simpara>
     </listitem>
    </varlistentry>
    <varlistentry xml:id="mongodb-driver-writeerror.props.index">
     <term><varname>index</varname></term>
     <listitem>
      <simpara>
       O índice da operação de gravação dentro do
       <classname>MongoDB\Driver\BulkWrite</classname> que causou o erro.
      </simpara>
     </listitem>
    </varlistentry>
    <varlistentry xml:id="mongodb-driver-writeerror.props.info">
     <term><varname>info</varname></term>
     <listitem>
      <simpara>
       Informações adicionais sobre o erro, ou &null; se não disponíveis.
      </simpara>
     </listitem>
    </varlistentry>
   </variablelist>
