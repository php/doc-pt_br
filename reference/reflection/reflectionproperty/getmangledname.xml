<refentry xml:id="reflectionproperty.getmangledname" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>ReflectionProperty::getMangledName</refname>
  <refpurpose>Obtém o nome codificado da propriedade</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis role="ReflectionProperty">
   <modifier>public</modifier> <type>string</type><methodname>ReflectionProperty::getMangledName</methodname>
   <void/>
  </methodsynopsis>
  <simpara>
   Retorna o nome codificado (interno) da propriedade, que codifica o
   escopo de visibilidade para propriedades privadas e protegidas.
  </simpara>
  <simpara>
   Para propriedades públicas, o nome codificado é idêntico ao nome da propriedade.
   Para propriedades protegidas, o nome codificado tem a forma
   <literal>\0*\0<replaceable>nome</replaceable></literal>.
   Para propriedades privadas, o nome codificado tem a forma
   <literal>\0<replaceable>NomeDaClasse</replaceable>\0<replaceable>nome</replaceable></literal>.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   O nome codificado da propriedade refletida.
  </simpara>
 </refsect1>

