 </refsect1>

 <refsect1 role="examples">
  &reftitle.examples;
  <para>
   <example>
    <title>Uso básico</title>
    <programlisting role="php">
<![CDATA[
<?php
#[Attribute]
class Fruta {
}

#[Attribute]
class Vermelha {
}

#[Fruta]
#[Vermelha]
const CEREJA = 'cereja';

$constant = new ReflectionConstant('CEREJA');
$attributes = $constant->getAttributes();
print_r(array_map(fn($attribute) => $attribute->getName(), $attributes));
?>
]]>
    </programlisting>
    &example.outputs;
    <screen>
<![CDATA[
Array
(
    [0] => Fruta
    [1] => Vermelha
)
]]>
    </screen>
   </example>
  </para>
 </refsect1>

